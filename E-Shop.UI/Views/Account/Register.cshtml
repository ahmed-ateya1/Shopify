@using E_Shop.Domain.Enums
@model E_Shop.Application.Dtos.AccountDtos.RegisterDto
@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-80">
            <div class="col-lg-5 col-md-7">
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-header text-center">
                        <div class="auth-icon register-icon">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <h3 class="auth-title">Create Account</h3>
                        <p class="auth-subtitle">Join E-Shop and start shopping today</p>
                    </div>

                    <!-- Form -->
                    <div class="auth-body">
                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label fw-semibold">
                                    <i class="fas fa-user me-1 text-muted"></i> Full Name
                                </label>
                                <input asp-for="FullName" class="form-control form-control-lg auth-input" placeholder="John Doe" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    <i class="fas fa-envelope me-1 text-muted"></i> Email Address
                                </label>
                                <input asp-for="Email" class="form-control form-control-lg auth-input" placeholder="you@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold">
                                    <i class="fas fa-lock me-1 text-muted"></i> Password
                                </label>
                                <div class="input-group">
                                    <input asp-for="Password" class="form-control form-control-lg auth-input" placeholder="Create a strong password" />
                                    <button class="btn btn-outline-secondary toggle-password" type="button">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ConfirmPassword" class="form-label fw-semibold">
                                    <i class="fas fa-lock me-1 text-muted"></i> Confirm Password
                                </label>
                                <div class="input-group">
                                    <input asp-for="ConfirmPassword" class="form-control form-control-lg auth-input" placeholder="Re-enter your password" />
                                    <button class="btn btn-outline-secondary toggle-password" type="button">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("ADMIN"))
                            {
                                <div class="mb-3">
                                    <label asp-for="UserOption" class="form-label fw-semibold">
                                        <i class="fas fa-user-tag me-1 text-muted"></i> User Role
                                    </label>
                                    <select asp-for="UserOption"
                                            class="form-select form-select-lg auth-input"
                                            asp-items="Html.GetEnumSelectList<UserOption>()">
                                    </select>
                                    <span asp-validation-for="UserOption" class="text-danger small"></span>
                                </div>
                            }

                            <div class="d-grid mb-3 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg auth-btn">
                                    <i class="fas fa-user-plus me-2"></i> Create Account
                                </button>
                            </div>

                            <div class="divider">
                                <span>or</span>
                            </div>

                            <div class="text-center mt-3">
                                <p class="mb-0 text-muted">
                                    Already have an account?
                                    <a asp-action="Login" asp-controller="Account" class="fw-semibold text-decoration-none register-link">
                                        Sign In
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const input = this.previousElementSibling;
                const icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });
    </script>
}