@model E_Shop.Application.Dtos.AccountDtos.LoginDto
@{
    ViewBag.Title = "Login";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-80">
            <div class="col-lg-5 col-md-7">
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-header text-center">
                        <div class="auth-icon">
                            <i class="fas fa-user-lock"></i>
                        </div>
                        <h3 class="auth-title">Welcome Back</h3>
                        <p class="auth-subtitle">Sign in to your E-Shop account</p>
                    </div>

                    <!-- Form -->
                    <div class="auth-body">
                        <form asp-action="Login" method="post">
                            <input type="hidden" name="returnURL" value="@ViewBag.ReturnUrl" />

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    <i class="fas fa-envelope me-1 text-muted"></i> Email Address
                                </label>
                                <input asp-for="Email" class="form-control form-control-lg auth-input" placeholder="you@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold">
                                    <i class="fas fa-lock me-1 text-muted"></i> Password
                                </label>
                                <div class="input-group">
                                    <input asp-for="Password" class="form-control form-control-lg auth-input" placeholder="Enter your password" />
                                    <button class="btn btn-outline-secondary toggle-password" type="button">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="RememberMe" />
                                    <label class="form-check-label small" asp-for="RememberMe">Remember me</label>
                                </div>
                                <a href="#" class="small text-decoration-none forgot-link">Forgot Password?</a>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-lg auth-btn">
                                    <i class="fas fa-sign-in-alt me-2"></i> Sign In
                                </button>
                            </div>

                            <div asp-validation-summary="All" class="text-danger small text-center"></div>

                            <div class="divider">
                                <span>or</span>
                            </div>

                            <div class="text-center mt-3">
                                <p class="mb-0 text-muted">
                                    Don't have an account?
                                    <a asp-action="Register" asp-controller="Account" class="fw-semibold text-decoration-none register-link">
                                        Create Account
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const input = this.previousElementSibling;
                const icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });
    </script>
}