@using E_Shop.Application.Dtos
@using E_Shop.Application.Dtos.OrderDtos
@using E_Shop.Domain.Enums
@model PaginatedResponse<OrderResponse>
@{
    ViewData["Title"] = "My Orders";
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<div class="orders-page">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">My Orders</li>
        </ol>
    </nav>

    <h2 class="page-heading"><i class="fas fa-box me-2"></i>My Orders</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Status Filter Tabs -->
    <div class="order-tabs mb-4">
        <a asp-action="Index" class="order-tab @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
            All Orders
        </a>
        @foreach (var s in Enum.GetValues<OrderStatus>())
        {
            <a asp-action="Index" asp-route-status="@s" class="order-tab @(currentStatus == s.ToString() ? "active" : "")">
                @s
            </a>
        }
    </div>

    @if (Model.Items.Any())
    {
        <div class="orders-list">
            @foreach (var order in Model.Items)
            {
                <div class="order-card">
                    <div class="order-card-header">
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="order-id">Order #@order.Id.ToString()[..8].ToUpper()</span>
                            <span class="order-date"><i class="far fa-calendar-alt me-1"></i>@order.OrderDate.ToString("MMM dd, yyyy")</span>
                            @{
                                var badgeClass = order.Status switch
                                {
                                    OrderStatus.Pending => "bg-warning text-dark",
                                    OrderStatus.Prosessing => "bg-info text-dark",
                                    OrderStatus.Shipped => "bg-primary",
                                    OrderStatus.Completed => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@order.Status</span>
                        </div>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-eye me-1"></i>View Details
                        </a>
                    </div>
                    <div class="order-card-body">
                        <div class="order-items-preview">
                            @foreach (var item in order.Items.Take(3))
                            {
                                <div class="order-item-mini">
                                    @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                    {
                                        <img src="@item.ProductImageUrl" alt="@item.ProductName" class="order-item-mini-img" />
                                    }
                                    else
                                    {
                                        <div class="order-item-mini-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                    <div>
                                        <small class="fw-semibold">@item.ProductName</small>
                                        <small class="text-muted d-block">Qty: @item.Quantity</small>
                                    </div>
                                </div>
                            }
                            @if (order.Items.Count() > 3)
                            {
                                <small class="text-muted">+@(order.Items.Count() - 3) more item(s)</small>
                            }
                        </div>
                        <div class="order-total-col">
                            <small class="text-muted">Total</small>
                            <strong class="order-amount">$@order.TotalAmount.ToString("N2")</strong>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav class="mt-4" aria-label="Orders pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage - 1)">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage + 1)">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-box-open"></i>
            <h4>No orders found</h4>
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-shopping-bag me-2"></i>Start Shopping
            </a>
        </div>
    }
</div>
