@using E_Shop.Domain.Models
@model Cart
@{
    ViewData["Title"] = "Shopping Cart";
    var items = Model.CartItems;
    var subtotal = items.Sum(i => i.Price * i.Quantity);
}

<div class="cart-page">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index">Shop</a></li>
            <li class="breadcrumb-item active">Cart</li>
        </ol>
    </nav>

    <h2 class="page-heading"><i class="fas fa-shopping-cart me-2"></i>Shopping Cart</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-items-card">
                    <div class="cart-header">
                        <span>Product</span>
                        <span>Price</span>
                        <span>Quantity</span>
                        <span>Total</span>
                        <span></span>
                    </div>
                    @foreach (var item in items)
                    {
                        <div class="cart-item">
                            <div class="cart-product">
                                <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductID">
                                    @if (!string.IsNullOrEmpty(item.PictureUrl))
                                    {
                                        <img src="@item.PictureUrl" alt="@item.ProductName" class="cart-item-img" />
                                    }
                                    else
                                    {
                                        <div class="cart-item-img-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                </a>
                                <div>
                                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductID" class="cart-item-name">
                                        @item.ProductName
                                    </a>
                                </div>
                            </div>
                            <div class="cart-price">$@item.Price.ToString("N2")</div>
                            <div class="cart-qty">
                                <form asp-action="Update" method="post" class="qty-form">
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <input type="hidden" class="stock-quantity" value="@item.StockQuantity" />
                                    <div class="qty-selector">
                                        <button type="button" class="btn btn-outline-secondary qty-btn" data-action="decrease">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" max="@item.StockQuantity"
                                               class="form-control qty-input" />
                                        <button type="button" class="btn btn-outline-secondary qty-btn" data-action="increase" 
                                                @(item.Quantity >= item.StockQuantity ? "disabled" : "")>
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                    @if (item.StockQuantity <= 10)
                                    {
                                        <small class="text-warning d-block mt-1">
                                            <i class="fas fa-exclamation-triangle"></i> Only @item.StockQuantity left
                                        </small>
                                    }
                                </form>
                            </div>
                            <div class="cart-total">$@((item.Price * item.Quantity).ToString("N2"))</div>
                            <div class="cart-remove">
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="summary-card">
                    <h5 class="summary-title">Order Summary</h5>
                    <div class="summary-row">
                        <span>Subtotal (@items.Sum(i => i.Quantity) items)</span>
                        <span>$@subtotal.ToString("N2")</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr />
                    <div class="summary-row summary-total">
                        <span>Total</span>
                        <span>$@subtotal.ToString("N2")</span>
                    </div>

                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary w-100 mt-3 btn-checkout">
                        <i class="fas fa-lock me-2"></i>Proceed to Checkout
                    </a>

                    <div class="secure-badge mt-3 text-center">
                        <i class="fas fa-shield-alt me-1"></i>
                        <small class="text-muted">Secure Checkout</small>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-shopping-cart"></i>
            <h4>Your cart is empty</h4>
            <p class="text-muted">Looks like you haven't added any products yet.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-shopping-bag me-2"></i>Start Shopping
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.qty-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('.qty-form');
                const input = form.querySelector('.qty-input');
                const stockQuantity = parseInt(form.querySelector('.stock-quantity').value);
                const increaseBtn = form.querySelector('[data-action="increase"]');

                let val = parseInt(input.value) || 1;

                if (this.dataset.action === 'increase') {
                    if (val < stockQuantity) {
                        val++;
                    }
                } else if (this.dataset.action === 'decrease' && val > 1) {
                    val--;
                }

                input.value = val;

                // Disable/enable increment button based on stock
                if (val >= stockQuantity) {
                    increaseBtn.setAttribute('disabled', 'disabled');
                } else {
                    increaseBtn.removeAttribute('disabled');
                }

                form.submit();
            });
        });

        document.querySelectorAll('.qty-input').forEach(input => {
            input.addEventListener('change', function () {
                const form = this.closest('.qty-form');
                const stockQuantity = parseInt(form.querySelector('.stock-quantity').value);

                if (this.value < 1) this.value = 1;
                if (this.value > stockQuantity) this.value = stockQuantity;

                this.closest('.qty-form').submit();
            });
        });

        // Update cart badge
        fetch('/Cart/GetCartCount')
            .then(r => r.json())
            .then(data => {
                document.querySelectorAll('.badge-cart').forEach(b => b.textContent = data.count);
            });
    </script>
}
