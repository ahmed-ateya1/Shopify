@using E_Shop.Application.Dtos.ProductDtos
@model ProductResponse
@{
    ViewData["Title"] = Model.Name;
    var relatedProducts = ViewBag.RelatedProducts as IEnumerable<ProductResponse>;
}

<div class="product-details-page">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index">Shop</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="detail-image-card sticky-top-gallery">
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <div class="main-image-wrapper">
                        <img id="mainImage" src="@Model.ImageUrls.First()" alt="@Model.Name" class="main-product-image"
                             onerror="this.src='';this.closest('.main-image-wrapper').innerHTML='<div class=\'product-image-placeholder large\'><i class=\'fas fa-image\'></i></div>'" />
                    </div>
                    <div class="image-thumbnails mt-3">
                        @foreach (var img in Model.ImageUrls)
                        {
                            <div class="thumb-item" onclick="switchImage(this, '@img')">
                                <img src="@img" alt="@Model.Name"
                                     onerror="this.closest('.thumb-item').style.display='none'" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="main-image-wrapper">
                        <div class="product-image-placeholder large">
                            <i class="fas fa-image"></i>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="detail-info-card">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="detail-sku"><i class="fas fa-barcode me-1"></i>SKU: @Model.SKU</span>
                    @if (Model.IsActive)
                    {
                        <span class="badge detail-active-badge">Active</span>
                    }
                </div>
                <h2 class="detail-name">@Model.Name</h2>

                <div class="detail-price-section">
                    <span class="detail-price">$@Model.Price.ToString("N2")</span>
                </div>

                <div class="detail-stock mb-3">
                    @if (Model.StockQuantity > 10)
                    {
                        <span class="stock-badge in-stock">
                            <i class="fas fa-check-circle me-1"></i> In Stock (@Model.StockQuantity available)
                        </span>
                    }
                    else if (Model.StockQuantity > 0)
                    {
                        <span class="stock-badge low-stock">
                            <i class="fas fa-exclamation-triangle me-1"></i> Low Stock (Only @Model.StockQuantity left)
                        </span>
                    }
                    else
                    {
                        <span class="stock-badge out-of-stock">
                            <i class="fas fa-times-circle me-1"></i> Out of Stock
                        </span>
                    }
                </div>

                <hr class="detail-divider" />

                <div class="detail-actions">
                    <label class="form-label fw-semibold mb-2">Quantity</label>
                    <form asp-controller="Cart" asp-action="Add" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="qty-selector">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="changeQty(-1)">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <input type="number" id="qtyInput" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control form-control-sm" />
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="changeQty(1)">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mb-4">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1 btn-add-cart" @(Model.StockQuantity == 0 ? "disabled" : "")>
                                <i class="fas fa-cart-plus me-2"></i> Add to Cart
                            </button>
                    </form>
                    <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-lg btn-wishlist" title="Add to Wishlist">
                            <i class="far fa-heart"></i>
                        </button>
                    </form>
                        </div>
                </div>

                <div class="detail-features">
                    <div class="feature-item">
                        <i class="fas fa-truck feature-icon-delivery"></i>
                        <div>
                            <strong>Free Delivery</strong>
                            <p>On orders over $50</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-undo-alt feature-icon-return"></i>
                        <div>
                            <strong>Easy Returns</strong>
                            <p>30 day return policy</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-shield-alt feature-icon-secure"></i>
                        <div>
                            <strong>Secure Payment</strong>
                            <p>SSL encrypted checkout</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (relatedProducts != null && relatedProducts.Any())
    {
        <div class="related-products mt-5">
            <h4 class="section-title"><i class="fas fa-th-large me-2"></i> Related Products</h4>
            <div class="row g-3">
                @foreach (var rp in relatedProducts)
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="product-card">
                            <a asp-action="Details" asp-route-id="@rp.Id" class="product-card-link">
                                <div class="product-image-wrapper">
                                    @if (rp.ImageUrls != null && rp.ImageUrls.Any())
                                    {
                                        <img src="@rp.ImageUrls.First()" alt="@rp.Name" class="product-image" />
                                    }
                                    else
                                    {
                                        <div class="product-image-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                </div>
                            </a>
                            <div class="product-info">
                                <h6 class="product-name">
                                    <a asp-action="Details" asp-route-id="@rp.Id">@rp.Name</a>
                                </h6>
                                <span class="product-price">$@rp.Price.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeQty(delta) {
            var input = document.getElementById('qtyInput');
            var val = parseInt(input.value) + delta;
            var max = parseInt(input.getAttribute('max'));
            if (val >= 1 && val <= max) {
                input.value = val;
            }
        }

        function switchImage(thumbEl, src) {
            document.getElementById('mainImage').src = src;
            document.querySelectorAll('.thumb-item').forEach(function (t) {
                t.classList.remove('active');
            });
            thumbEl.classList.add('active');
        }

        // Mark first visible thumbnail as active on load
        document.addEventListener('DOMContentLoaded', function () {
            var firstThumb = document.querySelector('.thumb-item');
            if (firstThumb) firstThumb.classList.add('active');
        });
    </script>
}
