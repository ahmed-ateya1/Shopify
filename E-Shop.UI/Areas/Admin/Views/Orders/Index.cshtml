@using E_Shop.Application.Dtos
@using E_Shop.Application.Dtos.OrderDtos
@using E_Shop.Domain.Enums
@model PaginatedResponse<OrderResponse>
@{
    ViewData["Title"] = "Orders";
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-shopping-bag me-2"></i>Orders</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card mb-3">
    <div class="admin-card-body py-2">
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(currentStatus) ? "btn-primary" : "btn-outline-secondary")">
                All
            </a>
            @foreach (var s in Enum.GetValues<OrderStatus>())
            {
                <a asp-action="Index" asp-route-status="@s"
                   class="btn btn-sm @(currentStatus == s.ToString() ? "btn-primary" : "btn-outline-secondary")">
                    @s
                </a>
            }
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var order in Model.Items)
                        {
                            var statusClass = order.Status.ToString().ToLower() switch
                            {
                                "pending" => "pending",
                                "prosessing" => "processing",
                                "shipped" => "shipped",
                                "completed" => "completed",
                                _ => "pending"
                            };
                            <tr>
                                <td class="fw-semibold">#@order.Id.ToString().Substring(0, 8).ToUpper()</td>
                                <td>@order.UserName</td>
                                <td class="text-muted small">@order.UserEmail</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>@order.Items.Count() items</td>
                                <td class="fw-semibold">$@order.TotalAmount.ToString("N2")</td>
                                <td><span class="status-badge @statusClass">@order.Status</span></td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn-action view" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                No orders found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage - 1)">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage + 1)">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
