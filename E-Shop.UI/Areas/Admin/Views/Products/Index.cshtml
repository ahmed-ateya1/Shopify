@using E_Shop.Application.Dtos
@using E_Shop.Application.Dtos.ProductDtos
@model PaginatedResponse<ProductResponse>
@{
    ViewData["Title"] = "Products";
    var searchQuery = ViewBag.SearchQuery as string;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-box me-2"></i>Products</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Add Product
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card mb-3">
    <div class="admin-card-body py-2">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="q" class="form-control border-start-0" placeholder="Search by name or SKU..." value="@searchQuery" />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var product in Model.Items)
                        {
                            <tr>
                                <td>
                                    @if (product.ImageUrls != null && product.ImageUrls.Any())
                                    {
                                        <img src="@product.ImageUrls.First()" alt="@product.Name" class="thumb-img" />
                                    }
                                    else
                                    {
                                        <div class="thumb-placeholder"><i class="fas fa-image"></i></div>
                                    }
                                </td>
                                <td class="fw-semibold">@product.Name</td>
                                <td><code>@product.SKU</code></td>
                                <td class="fw-semibold">$@product.Price.ToString("N2")</td>
                                <td>
                                    @if (product.StockQuantity > 10)
                                    {
                                        <span class="text-success fw-semibold">@product.StockQuantity</span>
                                    }
                                    else if (product.StockQuantity > 0)
                                    {
                                        <span class="text-warning fw-semibold">@product.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-semibold">0</span>
                                    }
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="status-badge shipped">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge pending">Inactive</span>
                                    }
                                </td>
                                <td class="text-muted small">@product.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn-action edit" title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@product.Id" method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this product?');">
                                            <button type="submit" class="btn-action delete" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-box-open fa-2x mb-2 d-block"></i>
                                No products found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(currentPage - 1)">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(currentPage + 1)">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
